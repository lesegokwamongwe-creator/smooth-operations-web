{
  "entities": {
    "LoanApplication": {
      "title": "Loan Application",
      "description": "A user's application for a loan.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who submitted the application."
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "idNumber": {
          "type": "string",
          "description": "South African ID number (13 digits)."
        },
        "mobile": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "netIncome": {
          "type": "number",
          "description": "Monthly net income."
        },
        "loanAmount": {
          "type": "number",
          "description": "Requested loan amount."
        },
        "status": {
          "type": "string",
          "enum": ["Pending Review", "Approved", "Declined"],
          "description": "Current status of the application."
        },
        "date": {
          "type": "string",
          "description": "Date of application (YYYY-MM-DD)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "bankName": {
          "type": "string",
          "description": "Name of the user's bank."
        },
        "accountNumber": {
          "type": "string",
          "description": "User's bank account number."
        },
        "accountType": {
          "type": "string",
          "description": "Type of the bank account (e.g., Savings, Cheque)."
        },
        "payslipData": {
          "type": "string",
          "description": "Base64 encoded string of the uploaded payslip."
        },
        "declineReason": {
          "type": "string",
          "description": "General reason for application rejection if status is Declined."
        },
        "repaymentDate": {
          "type": "string",
          "description": "Date when the loan repayment is due (YYYY-MM-DD)."
        },
        "repaymentAmount": {
          "type": "number",
          "description": "Total amount to be repaid."
        },
        "lastReminderSent": {
          "type": "string",
          "description": "Timestamp of the last reminder sent."
        },
        "applicationNumber": {
          "type": "number",
          "description": "Sequential application number."
        }
      },
      "required": [
        "userId",
        "firstName",
        "lastName",
        "idNumber",
        "mobile",
        "email",
        "netIncome",
        "loanAmount",
        "status",
        "date",
        "createdAt",
        "bankName",
        "accountNumber",
        "accountType",
        "payslipData",
        "applicationNumber"
      ]
    },
    "User": {
      "title": "User Profile",
      "description": "A user's profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "email": { "type": "boolean" },
            "sms": { "type": "boolean" },
            "newApplications": { "type": "boolean" },
            "highValueLoans": { "type": "boolean" },
            "overduePayments": { "type": "boolean" },
            "highValueThreshold": { "type": "number" }
          }
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in the financial coach chat.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["user", "model"],
          "description": "The sender of the message."
        },
        "text": {
          "type": "string",
          "description": "The content of the message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was created."
        }
      },
      "required": ["role", "text", "createdAt"]
    },
    "Counter": {
      "title": "Counter",
      "description": "A global counter for sequential IDs.",
      "type": "object",
      "properties": {
        "count": {
          "type": "number",
          "description": "The current count."
        }
      },
      "required": ["count"]
    }
  },
  "firestore": {
    "/applications/{applicationId}": {
      "schema": {
        "$ref": "#/entities/LoanApplication"
      },
      "description": "Stores all loan applications."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profile information."
    },
    "/users/{userId}/chatMessages/{messageId}": {
      "schema": {
        "$ref": "#/entities/ChatMessage"
      },
      "description": "Stores chat history for the financial coach."
    },
    "/counters/{counterId}": {
      "schema": {
        "$ref": "#/entities/Counter"
      },
      "description": "Stores global counters."
    }
  }
}
